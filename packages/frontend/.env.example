# Meal service GraphQL
# Simulator/web: localhost. Physical device: http://<your-lan-ip>:4002/graphql
EXPO_PUBLIC_API_URL=http://localhost:4002/graphql

# User service (Better Auth + profile API)
EXPO_PUBLIC_USER_SERVICE_URL=http://localhost:4001

# Origin sent on auth requests from React Native (must match user-service trustedOrigins)
EXPO_PUBLIC_APP_ORIGIN=dishlist://
