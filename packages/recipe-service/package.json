{
  "name": "recipe-service",
  "version": "0.0.1",
  "description": "",
  "author": "",
  "private": true,
  "type": "module",
  "license": "UNLICENSED",
  "scripts": {
    "build": "pnpm db:generate && tsc -p tsconfig.build.json",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "pnpm db:generate && pnpm db:push && tsx src/server.ts",
    "start:dev": "pnpm db:generate && pnpm db:push && tsx watch src/server.ts",
    "lint": "eslint \"{src,jobs,test}/**/*.ts\" --fix",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:cov": "vitest run --coverage",
    "test:e2e": "vitest run",
    "db:generate": "prisma generate --schema=prisma/schema.prisma",
    "db:generate:all": "pnpm db:generate",
    "db:push": "prisma db push --schema=prisma/schema.prisma",
    "db:migrate-ingredients": "tsx scripts/migrate-ingredients-to-json.ts",
    "db:migrate": "prisma migrate dev --schema=prisma/schema.prisma",
    "db:studio": "prisma studio --schema=prisma/schema.prisma",
    "s3-recipe:ingest": "tsx jobs/s3-recipe-ingestion.ts",
    "s3-recipe:ingest:prod": "node dist/jobs/s3-recipe-ingestion.js"
  },
  "dependencies": {
    "@apollo/subgraph": "^2.12.2",
    "@aws-sdk/client-s3": "^3.1048.0",
    "@aws-sdk/s3-request-presigner": "^3.1048.0",
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "graphql": "^16.12.0",
    "graphql-yoga": "^5.18.0",
    "jose": "^6.2.3",
    "pg": "^8.13.1",
    "reflect-metadata": "^0.2.2",
    "tsyringe": "^4.10.0",
    "uuid": "^11.0.3"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.18.0",
    "@types/node": "^22.10.7",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^6.0.2",
    "@vitest/coverage-v8": "^3.2.4",
    "eslint": "^9.18.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-prettier": "^5.2.2",
    "globals": "^16.0.0",
    "prettier": "^3.4.2",
    "prisma": "^7.0.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.19.4",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.20.0",
    "vitest": "^3.2.4"
  }
}
